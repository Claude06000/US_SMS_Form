# Variables d'environnement pour l'envoi d'email
# Copier ce fichier en .env et remplir les valeurs

# Clé API Resend (https://resend.com/api-keys)
NUXT_RESEND_API_KEY=re_xxxxxxxxxx

# Email destinataire (qui recevra les soumissions)
NUXT_RECIPIENT_EMAIL=dev@noviamind.ai

# Email expéditeur (doit être un domaine vérifié dans Resend)
NUXT_SENDER_EMAIL=noreply@noviamind.ai

# Nom d'affichage de l'expéditeur
NUXT_SENDER_EMAIL_NAME=NoviaMind
